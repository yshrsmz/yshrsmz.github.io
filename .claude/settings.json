{
  "language": "Japanese",
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "WebSearch"
    ],
    "deny": [],
    "ask": [
      "Bash(codex:*)",
      "Bash(git push:*)"
    ]
